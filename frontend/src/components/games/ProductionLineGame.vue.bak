              </div>
              
              <!-- 濞戞挸顑嗛弸鈩冨閻樼儵鍋撴担鍝ユ暔 -->
              <div class="device output" :class="{ active: devices.output.active }">
                <div class="device-label">濞戞挸顑嗛弸鈩冨閻樼儵鍋撴担鍝ユ暔</div>
                <div class="conveyor-visual">
                  <div class="conveyor-belt" :class="{ moving: devices.output.active }">
                    <span class="belt-segment">闁/span>
                    <span class="belt-segment">闁/span>
                    <span class="belt-segment">闁/span>
                    <span class="belt-segment">闁/span>
                    <span class="belt-segment">闁/span>
                  </div>
                  <div class="output-count">闁?{{ completedCount }} 濞/div>
                </div>
              </div>
            </div>
            
            <!-- 濞戞搩鍙冨Λ鍧楁晬濮橆剚濡囩憸鑸灱濞村棝鎯?-->
            <div class="middle-row">
              <div class="turntable-container">
                <div class="turntable-label">闁搞儲绋戞导鎰媴瀹ュ牊绁柣/div>
                <div class="turntable" :class="{ rotating: devices.turntable.rotating }" 
                     :style="{ transform: `rotate(${turntableRotation}deg)` }">
                  <!-- 濞戞搩鍘肩缓?-->
                  <div class="turntable-center">
                    <span class="center-icon">闁虫寧鐟辩粭?/span>
                  </div>
                  <!-- 闁搞儲绋愰柌婊冾啅閵夈倗绉?-->
                  <div class="station station-1" :class="{ hasMaterial: devices.turntable.stations[0].hasMaterial }">
                    <span class="station-name">濞戞挸锕ラ弸?/span>
                    <span class="station-material" v-if="devices.turntable.stations[0].hasMaterial">妫ｅ啯鎲?/span>
                  </div>
                  <div class="station station-2" :class="{ hasMaterial: devices.turntable.stations[1].hasMaterial }">
                    <span class="station-name">闁告梻濮存导?/span>
                    <span class="station-material" v-if="devices.turntable.stations[1].hasMaterial">妫ｅ啯鎲?/span>
                  </div>
                  <div class="station station-3" :class="{ hasMaterial: devices.turntable.stations[2].hasMaterial }">
                    <span class="station-name">濞戞挸顑嗛弸?/span>
                    <span class="station-material" v-if="devices.turntable.stations[2].hasMaterial">妫ｅ啯鎲?/span>
                  </div>
                  <div class="station station-4" :class="{ hasMaterial: devices.turntable.stations[3].hasMaterial }">
                    <span class="station-name">缂佸矁妗ㄧ紞?/span>
                    <span class="station-material" v-if="devices.turntable.stations[3].hasMaterial">妫ｅ啯鎲?/span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- 閺夆晜鍔橀、鎴︽偐閼哥鍋撴担鐟扮倒缂佲偓?-->
          <div v-if="debugMode" class="debug-notice">
            <span>妫ｅ啯鏆?閻犲鍟抽惁顖毼熼垾宕囩</span>
            <span>閺夆晜鍔橀、鎴炵▔椤撶偛璁查梻鍛箲濡炲倿宕戝鍕靛壘濞ｅ浂鍠楅弫濂告晬鐏炶偐鐟濆ù鍏艰壘閸ㄧ晫鈧鑹鹃妵鎴犳嫻/span>
          </div>
          
          <div v-if="showSuccess" class="success-overlay">
            <div class="success-content">
              <span class="success-icon">妫ｅ啫绔?/span>
              <span>闁稿繐鍟垮畷閬嶆焻濮樺磭绠栭柨/span>
              <div class="stats">
                <span>闁活潿鍔嶅? {{ elapsedTime }}缂/span>
                <span>闁告柣鍔嬬紞鏃堝极? {{ flow.length }}</span>
              </div>
              <button class="btn-next" @click="nextLevel">濞戞挸顑勭粩鎾礂?/button>
            </div>
          </div>
        </div>
        
        <!-- 闁告瑥鍘栭弲鍫曟晬濮橆剙袟濞达絾绮庣槐顏堝箳閹烘垵闅?-->
        <div class="action-area">
          <!-- 閻熸瑥瀚崹顖炲箵閹邦喓浠?-->
          <div class="rules-panel">
            <p class="mission">妫ｅ啯鎲?{{ currentLevel.mission }}</p>
            <div class="rules">
              <h4>妫ｅ啯鎯?閻熸瑥瀚崹顖炲箵閹邦喓浠?/h4>
              <div class="rule-list">
                <p v-for="(rule, idx) in currentLevel.rules.slice(0, 5)" :key="idx">{{ rule }}</p>
              </div>
            </div>
          </div>
          
          <!-- 闁告柣鍔嬬紞鏃€鎯?-->
          <div class="action-library">
            <h4>妫ｅ唭?闁告柣鍔嬬紞鏃€鎯旈幙鍕闁告瑥鑻崵顔记庣拠鎻掝潱闁?h4>
            <div class="action-grid">
              <div
                v-for="action in currentLevel.availableActions"
                :key="action"
                class="action-block"
                :style="{ borderColor: actionBlocks[action]?.color }"
                @dblclick="addAction(action)"
              >
                <span class="action-icon">{{ actionBlocks[action]?.icon }}</span>
                <span class="action-name">{{ actionBlocks[action]?.label }}</span>
              </div>
