}

/* 闁烩晩鍠楅悥锝夋閵忊剝绶?*/
.goal-panel {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10px;
  padding: 12px;
}

.goal-panel h4 {
  font-size: 13px;
  margin-bottom: 8px;
}

.goal-text {
  font-size: 12px;
  margin-bottom: 10px;
  line-height: 1.4;
}

.progress-bar {
  height: 8px;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 8px;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #00d4ff, #27ae60);
  border-radius: 4px;
  transition: width 0.3s;
}

.progress-text {
  font-size: 12px;
  color: #00d4ff;
  font-weight: 600;
}

/* 闁瑰瓨鍔曞銊ヮ嚕閸︻厾宕?*/
.achievement-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.achievement-content {
  background: linear-gradient(135deg, #1a1a3a 0%, #2a2a4a 100%);
  border: 2px solid #ffd700;
  border-radius: 20px;
  padding: 30px 50px;
  text-align: center;
}

.achievement-content h3 {
  color: #ffd700;
  margin-bottom: 20px;
}

.achievement-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.achievement-icon {
  font-size: 48px;
}

.achievement-name {
  font-size: 20px;
  font-weight: 600;
}

.btn-close {
  background: #ffd700;
  color: #1a1a3a;
  border: none;
  padding: 10px 30px;
  border-radius: 10px;
  font-size: 16px;
  cursor: pointer;
}

@media (max-width: 1024px) {
  .game-main {
    grid-template-columns: 1fr;
  }
  
  .top-row {
    grid-template-columns: 1fr;
  }
}
</style>


