                      <div class="arm-vertical" :class="{ down: devices.arm.down }">
                        <span class="arm-gripper">{{ devices.arm.holding ? '闁? : '妫ｅ啯鐎? }}</span>
                        <span class="held-material" v-if="devices.arm.holding">妫ｅ啯鎲?/span>
                      </div>
                    </div>
                  </div>
